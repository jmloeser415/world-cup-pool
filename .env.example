# Copy this file to ".env" and fill in the values. NEVER commit .env.

# Free token from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_org_token

# The Make/Supabase edge function the website reads from (base URL, no trailing /stats).
STATS_PUSH_URL=https://qhvgsbqpyzmxuzfrbmnd.supabase.co/functions/v1/make-server-73288676
# The Supabase anon (public) key — the SAME key the frontend uses. Safe to keep here;
# it's protected by the edge function. (Not the service_role key.)
SUPABASE_ANON_KEY=your_anon_public_key

# Optional: sanity-check scoring against a PAST World Cup (e.g. 2022). Leave blank for 2026.
WC_SEASON=
